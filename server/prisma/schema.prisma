datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ELECTION_COMMITTEE
  ADMIN
  VOTER
}

enum ElectionStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum TokenStatus {
  ISSUED
  CONSUMED
  REVOKED
}

// Denormalized, cached on Voter for fast list/filter/reporting; kept in sync transactionally
// whenever a VotingToken changes state. VotingToken rows remain the source of truth.
enum VoterVotingStatus {
  NOT_ISSUED
  ISSUED
  VOTED
  REVOKED
}

model User {
  id                      String        @id @default(uuid())
  email                   String        @unique
  passwordHash            String
  fullName                String
  role                    Role          @default(ADMIN)
  isActive                Boolean       @default(true)
  passwordResetTokenHash  String?       @unique
  passwordResetExpiresAt  DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  sessions                Session[]
  auditLogs               AuditLog[]
  tokensIssued            VotingToken[] @relation("TokenIssuedBy")
  tokensRevoked           VotingToken[] @relation("TokenRevokedBy")
  electionsLocked         Election[]    @relation("ElectionLockedBy")
  electionsUnlocked       Election[]    @relation("ElectionUnlockedBy")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

model Election {
  id            String         @id @default(uuid())
  title         String
  year          Int            // Configurable election year (e.g. 2024, 2026)
  description   String?
  status        ElectionStatus @default(DRAFT)
  startTime     DateTime?
  endTime       DateTime?
  settings      Json?          // Dynamic JSON settings

  // Election Lock: an independent read-only guard, layered on top of `status`. Closing an
  // election locks it automatically; a lock can also be triggered manually at any time (the
  // dashboard's "Emergency Lock"). Only a SUPER_ADMIN may unlock. Full history of every
  // lock/unlock cycle lives in AuditLog — these fields only reflect the current state.
  isLocked      Boolean        @default(false)
  lockedAt      DateTime?
  lockedById    String?
  lockedBy      User?          @relation("ElectionLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  unlockedAt    DateTime?
  unlockedById  String?
  unlockedBy    User?          @relation("ElectionUnlockedBy", fields: [unlockedById], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  positions        Position[]
  voters           Voter[]
  votingTokens     VotingToken[]
  votes            Vote[]
  auditLogs        AuditLog[]
  candidateTallies CandidateTally[]
  positionTallies  PositionTally[]
  tally            ElectionTally?
  activityBuckets  ActivityBucket[]
  resultSnapshot   ElectionResultSnapshot?

  @@map("elections")
}

model Position {
  id            String      @id @default(uuid())
  electionId    String
  election      Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  maxSelections Int         @default(1)
  displayOrder  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  candidates    Candidate[]
  votes         Vote[]
  tally         PositionTally?

  @@map("positions")
}

model Candidate {
  id           String    @id @default(uuid())
  positionId   String
  position     Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  electionId   String
  name         String
  bio          String?
  photoUrl     String?
  displayOrder Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  votes        Vote[]
  tally        CandidateTally?

  @@map("candidates")
}

model Voter {
  id               String            @id @default(uuid())
  electionId       String
  election         Election          @relation(fields: [electionId], references: [id], onDelete: Cascade)
  membershipNumber String            // e.g. IDA-000-000
  fullName         String
  email            String?
  phone            String?
  ward             String?           // e.g. Ward 01 - Okore
  isActive         Boolean           @default(true)
  votingStatus     VoterVotingStatus @default(NOT_ISSUED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tokens           VotingToken[]
  votes            Vote[]

  @@unique([electionId, membershipNumber])
  @@map("voters")
}

// Voting tokens are immutable once created: never mutated back to "unused" or reassigned.
// Replacing a token means revoking the current one and issuing a brand new row, linked via
// replacesTokenId so the full chain of custody survives for audit purposes.
model VotingToken {
  id              String       @id @default(uuid())
  voterId         String
  voter           Voter        @relation(fields: [voterId], references: [id], onDelete: Cascade)
  electionId      String
  election        Election     @relation(fields: [electionId], references: [id], onDelete: Cascade)
  tokenHash       String       @unique  // sha256 of the raw token; used for O(1) verification lookups
  tokenEncrypted  String       // AES-256-GCM ciphertext of the raw token; lets admins re-display/re-export a link without ever storing it in plaintext
  status          TokenStatus  @default(ISSUED)

  issuedAt        DateTime     @default(now())
  issuedById      String?
  issuedBy        User?        @relation("TokenIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)

  firstAccessedAt DateTime?
  consumedAt      DateTime?

  revokedAt       DateTime?
  revokedById     String?
  revokedBy       User?        @relation("TokenRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  expiresAt       DateTime?

  replacesTokenId String?      @unique
  replacesToken   VotingToken? @relation("TokenChain", fields: [replacesTokenId], references: [id])
  replacedBy      VotingToken? @relation("TokenChain")

  @@index([voterId])
  @@map("voting_tokens")
}

// OPEN BALLOT with controlled access: individual vote records are traceable to the voter who
// cast them (by design, per election committee decision), but visibility is restricted at the
// application layer to ELECTION_COMMITTEE/SUPER_ADMIN roles, never exposed via exports/reports/
// public APIs, and every read of individual records is itself audit-logged. See voting.service.ts.
model Vote {
  id              String    @id @default(uuid())
  electionId      String
  election        Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  positionId      String
  position        Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voterId         String
  voter           Voter     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  referenceNumber String    // shared across every position in one ballot submission; shown to the voter as their receipt
  castAt          DateTime  @default(now())

  @@unique([voterId, positionId, candidateId])
  @@index([electionId])
  @@index([referenceNumber])
  @@map("votes")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // e.g. ADMIN_LOGIN, ELECTION_OPENED, VOTE_CAST
  actorId    String?  // Can link to user id or voter session context
  actorRole  Role?    // ADMIN or VOTER
  actorName  String?  // Text description of the actor for readability
  targetType String?  // e.g. CANDIDATE, VOTER, ELECTION
  targetId   String?
  metadata   Json?    // Detailed dynamic context (e.g. IPs, changes list)
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())
  
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  electionId String?
  election   Election? @relation(fields: [electionId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Analytics engine — the single source of truth for every election statistic (Dashboard, Live
// Results, and Reports all read through server/src/modules/analytics/analytics.service.ts, which
// is the only code allowed to query these four tables directly). Kept updated by lightweight
// counters incremented inside the existing castVote transaction (see voting.service.ts) rather than
// recomputed from the Vote table on every read — reads stay O(candidates/positions), never O(votes).
// ---------------------------------------------------------------------------

// One row per candidate, created alongside it. voteCount is incremented transactionally in
// castVote — never written anywhere else except reconcileTallies' drift-repair path.
model CandidateTally {
  id          String    @id @default(uuid())
  electionId  String
  election    Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  positionId  String
  voteCount   Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@index([electionId])
  @@index([positionId])
  @@map("candidate_tallies")
}

// One row per election. ballotsCast counts submitted ballots (one per castVote call), not
// individual Vote rows — a ballot spans every position on that voter's selections.
model ElectionTally {
  id          String    @id @default(uuid())
  electionId  String    @unique
  election    Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  ballotsCast Int       @default(0)
  lastVoteAt  DateTime?

  @@map("election_tallies")
}

// One row per position, tracking true position-level abstentions directly rather than deriving
// them from candidate tallies. Deriving abstentions as (ballotsCast - sum of candidate votes) only
// works when maxSelections = 1; for a "select up to N" position a ballot can partially select
// without fully abstaining, so abstention needs its own counter, incremented in castVote whenever
// a submission's selection for this position is empty.
model PositionTally {
  id          String   @id @default(uuid())
  electionId  String
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  positionId  String   @unique
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  abstentions Int      @default(0)

  @@map("position_tallies")
}

// Hourly ballot counts per election, backing both the "hourly voting activity" chart and
// cumulative participation-trend calculations from the same underlying rows.
model ActivityBucket {
  id          String   @id @default(uuid())
  electionId  String
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  hourBucket  DateTime
  ballotsCast Int      @default(0)

  @@unique([electionId, hourBucket])
  @@map("activity_buckets")
}

// Written once, by certifyElectionResults, when an election is closed. Frozen forever after —
// closed/archived elections always read `data` verbatim rather than recomputing, so certified
// figures can never drift even if the underlying tally tables were ever repaired or reset.
// schemaVersion guards against a future payload-shape change breaking old certified snapshots.
model ElectionResultSnapshot {
  id            String   @id @default(uuid())
  electionId    String   @unique
  election      Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  schemaVersion Int
  data          Json
  certifiedAt   DateTime @default(now())
  certifiedById String?

  @@map("election_result_snapshots")
}
