# PostgreSQL connection (Supabase: use the pooled "Transaction" connection string for DATABASE_URL
# and the direct connection string for DIRECT_URL, which Prisma needs for migrations).
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Voting tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY="replace-with-a-64-char-hex-string-32-bytes"
# Public origin voting links are built from: {VOTING_LINK_BASE_URL}/vote/{token}
VOTING_LINK_BASE_URL="http://localhost:5173"

# Bootstrap election used until the Election Management module ships (see src/lib/election.ts)
DEFAULT_ELECTION_TITLE="General Election"

# Bootstrap admin created by `npm run prisma:seed` (change the password immediately after first login)
SEED_ADMIN_EMAIL="admin@igarra-da.org"
SEED_ADMIN_NAME="IDA Electoral Committee"
SEED_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"
