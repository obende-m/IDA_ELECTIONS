# PostgreSQL connection (Supabase: use the pooled "Transaction" connection string for DATABASE_URL
# and the direct connection string for DIRECT_URL, which Prisma needs for migrations).
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Refresh-token cookie policy. 'strict' (default) is correct when the frontend and backend share a
# site — localhost dev, or same registrable domain in production (e.g. app.igarra-da.org +
# api.igarra-da.org). Set to 'none' when deploying to default Vercel/Render domains (*.vercel.app /
# *.onrender.com are cross-site, and Strict cookies simply aren't sent cross-site at all) — 'none'
# requires HTTPS and is paired automatically with Secure regardless of NODE_ENV (see
# auth.controller.ts). requireTrustedOrigin (middleware/csrfOrigin.ts) compensates for the CSRF
# protection Strict was otherwise providing.
COOKIE_SAME_SITE=strict

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Voting tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY="replace-with-a-64-char-hex-string-32-bytes"
# Public origin voting links are built from: {VOTING_LINK_BASE_URL}/vote/{token}
VOTING_LINK_BASE_URL="http://localhost:5173"

# Bootstrap election used until the Election Management module ships (see src/lib/election.ts)
DEFAULT_ELECTION_TITLE="General Election"

# Bootstrap admin created by `npm run prisma:seed` (change the password immediately after first login)
SEED_ADMIN_EMAIL="admin@igarra-da.org"
SEED_ADMIN_NAME="IDA Electoral Committee"
SEED_ADMIN_PASSWORD="replace-with-a-strong-temporary-password"

# Supabase Storage (candidate photo uploads). Use the project's URL and the SERVICE ROLE key
# (not the anon key) — this is server-only and must never reach the client.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_PHOTOS_BUCKET="candidate-photos"
